[preset]
name: Audio Test

[effect]
vertex_shader:
void main() {
    gl_Position = vertex.attrib[8];
}
END
fragment_shader:
void main() {
    float rms = param 400;
    float mag0 = param 401;
    float mag1 = param 402;

    // Use RMS for intensity and magnitudes for color
    vec3 color = vec3(rms, mag0, mag1);
    gl_FragColor = vec4(color, 1.0);
}
END

[param]
param 400: 0.5
param 401: 0.5
param 402: 0.5
